---
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
    const artEntries = await getCollection("art");
    return artEntries.map(post => ({
        params: { slug: post.id },
        props: { post },
    }));
}
const { post } = Astro.props
const { Content } = await render(post)
---
<Layout title={post.data.title}>
    <article class='max-w-3xl mx-auto'>
        {post.data.image && (
            <Image
                src={post.data.image}
                alt={post.data.title}
                class='w-full rounded-xl mb-8 object-cover max-h-[500px]'
            />
        )}
        <h1 class='text-4xl font-bold mb-2'>{post.data.title}</h1>
        <div class='flex gap-4 mb-8 text-base-content/60 text-sm'>
            <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', {
                    year: 'numeric', month: 'long', day: 'numeric'
                })}
            </time>
            {post.data.medium && <span class='italic'>{post.data.medium}</span>}
            {(post.data.tags ?? []).map(tag => (
                <span class='badge badge-outline'>{tag}</span>
            ))}
        </div>
        <div class='prose prose-base max-w-none'>
            <Content />
        </div>
    </article>
</Layout>