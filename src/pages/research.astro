---
import Layout from "@/layouts/Layout.astro";
import { profile } from "@/settings";
import BetterIcon from "@/components/ui/BetterIcon.astro";
import List from "@/components/ui/List.astro";
import {RESEARCH_ICONS} from "@/data/researchIcons";

const { research_areas } = profile;
---

<Layout title="Research | Dr. Marie Curie">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Profile</h1>

    <div class="mb-12">
      <p class="text-lg mb-6">
        I'm an aspiring Technical Artist and Programmer with a passion for creating immersive experiences. I specialize in 3D modeling, shader development, and real-time graphics optimization.
      </p>
      <p class="text-lg mb-6">
        I have cultivated a background in both art and programming and hope to explore technology and creativity to bring virtual worlds to life.
      </p>
    </div>

    <h2 class="text-2xl font-bold mb-6">Areas of Study</h2>
    <div class="grid gap-8 mb-12">
      {
        research_areas.map((area) => (
          <div class="flex gap-6 items-start">
            <BetterIcon>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                class="size-6 stroke-accent"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={RESEARCH_ICONS[area.field as keyof typeof RESEARCH_ICONS]?.path || RESEARCH_ICONS['computer-science'].path}
                />
              </svg>
            </BetterIcon>
            <div>
              <h3 class="text-xl font-semibold mb-2">{area.title}</h3>
              <p class="text-base">{area.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <List listTitle="Current Projects" listItems={[
      {
        title: "C++ OpenGL Fps Game Team Project",
        description: "Investigation and Application of proper project planning alongside cooperation to create a cross-platform shooter game; to which will be playable on Playstation 5 utilizing University provided Developer Kits."
      },
      {
        title: "C++ OpenGL Individual Project",
        description: "A longer project intended to be a proof of mastery of teh content provided in my master's course. This project is one to which I am developing: render pipelining, asset creation, framework employment, system designing, shader manipulation, networking and state machine setup."
      }
    ]} />

    <h2 class="text-2xl font-bold mb-6">Future Plans</h2>
    <p class="text-lg mb-6">
      After my current education at Newcastle University, I hope to pursue a career in the gaming industry as a Technical Artist or Graphics Programmer. I am specifically interested in working on various-genred titles and contributing to the development of both cutting-edge graphics technologies and stylisticly dense projects.
    </p>
  </div>
</Layout>
